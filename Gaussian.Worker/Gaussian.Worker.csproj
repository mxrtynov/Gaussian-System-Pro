	<ItemGroup>
		<ProjectReference Include="..\Gaussian.Shared\Gaussian.Shared.csproj" />
		<ProjectReference Include="..\Gaussian.Solver\Gaussian.Solver.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="System.Management" Version="10.0.3" />
	</ItemGroup>

</Project>